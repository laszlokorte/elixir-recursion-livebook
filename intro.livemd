## LinkedListStructure

We can do the same for our linked list structure or even better for the Elixir/Erlang native linked list structure:

```elixir
defmodule LinkedListStructure do
  # a list is either empty or [head | tail] with tail being the recursive field
  def recursion(list, fun) do
    case list do
      [] ->
        []

      [head | tail] ->
        # notice how the fun.() call marks the recursive field
        [head | fun.(tail)]
    end
  end

  defmodule Algebras do
    # minimum value of a list
    def min(list) do
      case list do
        [] -> :infinity
        [h | t] -> min(h, t)
      end
    end

    # max value of a list
    def max(list) do
      case list do
        [] -> :neginf
        [h | t] -> maxi(h, t)
      end
    end

    # sum of a list
    def sum(list) do
      case list do
        [] -> 0
        [h | t] -> h + t
      end
    end

    def product(list) do
      case list do
        [] -> 1
        [h | t] -> h * t
      end
    end

    def length(list) do
      case list do
        [] -> 0
        [_h | t] -> 1 + t
      end
    end

    def contains?(el) do
      fn
        [] -> false
        [^el | _t] -> true
        [_el | t] -> t
      end
    end

    def any?(list) do
      case list do
        [] -> false
        [h | t] -> h or t
      end
    end

    def all?(list) do
      case list do
        [] -> true
        [h | t] -> h and t
      end
    end

    def reduce(initial, fun) do
      fn
        [] -> initial
        [h | t] -> fun.(h, t)
      end
    end

    def to_string_nested(list) do
      case list do
        [] -> "[]"
        [h | t] -> "[#{h} | #{t}]"
      end
    end

    def to_string_comma(list) do
      case list do
        [] -> "[]"
        [h | "[]"] -> "[#{h}]"
        [h | "[" <> t] -> "[#{h}, #{t}"
      end
    end

    defp maxi(:neginf, a), do: a
    defp maxi(a, :neginf), do: a
    defp maxi(a, b), do: Kernel.max(a, b)
  end
end

Kino.nothing()
```

