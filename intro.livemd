  def mapRecur(tree, fun) do
    case tree do
      {:leaf, value} ->
        {:leaf, value}

      {:inner, inner_value, left, right} ->
        {
          :inner,
          inner_value,
          fun.(left),  # <-- fun.() for the recursive fields
          fun.(right)  # <-- fun.() 
