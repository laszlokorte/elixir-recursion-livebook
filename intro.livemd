```
Search generated from list of numbers: false
```

```elixir
defmodule BinarySearchSequence.CoAlgebras do
  def binary_search_sequence_ana(needle) do
    fn
      :empty -> []
      {:leaf, ^needle} -> [needle | :empty]
      {:leaf, v} -> [v | :empty]
      {:inner, ^needle, _l, _r} -> [needle | :empty]
      {:inner, v, l, _r} when needle < v -> [v | l]
      {:inner, v, _l, r} when needle > v -> [v | r]
    end
  end

  def binary_search_ana(needle) do
    fn
      :empty -> []
      {:leaf, ^needle} -> [true | :empty]
      {:leaf, _v} -> []
      {:inner, ^needle, _l, _r} -> [true | :empty]
      {:inner, v, l, _r} when needle < v -> [false | l]
      {:inner, v, _l, r} when needle > v -> [false | r]
    end
  end

  def binary_search_direction_ana(needle) do
    fn
      :stop -> []
      :empty -> [:miss | :stop]
      {:leaf, ^needle} -> [:found | :stop]
      {:leaf, _v} -> [:miss | :stop]
      {:inner, ^needle, _l, _r} -> [:found | :stop]
      {:inner, v, l, _r} when needle < v -> [:left | l]
      {:inner, v, _l, r} when needle > v -> [:right | r]
    end
  end
end

Kino.nothing()
```

