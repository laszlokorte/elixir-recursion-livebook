## Catamorphism

This specific recursion scheme is called *catamorphism* because *cata* is greek for collapsing and what all our functions had in common is that they collapsed the trees or lists they were given into a single value. Yes, Array.reduce is also a catamorphism.

The function that we called `handleCases` is called an algebras because it captures the rules for turning a tree-like structure into a single value, the same way an algebra in math is about manipulating symbolic expressions and calculating their resulting value.

Lets acutally rename the `RecursiveReduction` module to `Catamorphism` and look at some more examples of how concise some algorithms can be expressed now.

```elixir
# defmodule RecursiveReduction do
defmodule Catamorphism do
  def cata(data, mapRecur, handleCases) do
    data
    |> mapRecur.(fn
      child -> cata(child, mapRecur, handleCases)
    end)
    |> handleCases.()
  end
end

Kino.nothing()
```

## SparseTreeStructure

Now we can express a recursive data structure as a combinations of mapping over its structure and so called algebras:

```elixir
defmodule SparseTreeStructure do
  # the structure of a tree with possibly empty nodes
  def recursion(tree, fun) do
    case tree do
      :empty ->
        :empty

      {:leaf, value} ->
        {:leaf, value}

      {:inner, inner_value, left, right} ->
        {
          :inner,
          inner_value,
          fun.(left),
          fun.(right)
        }
    end
  end

  # all the reductions that we can do with tree
  defmodule Algebras do
    def min(tree) do
      case tree do
        # The minimum of an empty tree is infinity
        :empty -> :infinity
        # The minimum of leaf is its values
        {:leaf, v} -> v
        # The minimum of an inner nodes is the minimum of both its children and its own balue
        {:inner, v, l, r} -> min(v, min(l, r))
      end
    end

    # calculate its max value
    def max(tree) do
      case tree do
        :empty -> :neginf
        {:leaf, v} -> v
        {:inner, v, l, r} -> maxi(v, maxi(l, r))
      end
    end

    # sum all values in both inner and leaf nodes
    def sum(tree) do
      case tree do
        :empty -> 0
        {:leaf, v} -> v
        {:inner, v, l, r} -> v + l + r
      end
    end

    # multiply all values
    def product(tree) do
      case tree do
        :empty -> 1
        {:leaf, v} -> v
        {:inner, v, l, r} -> v * l * r
      end
    end

    # turn the tree into a string of nested braces
    def to_string(tree) do
      case tree do
        :empty -> "(X)"
        {:leaf, v} -> "[#{v}]"
        {:inner, v, l, r} -> "{#{l}:#{v}:#{r}}"
      end
    end

    # check if the tree contains a value
    def contains(el) do
      fn
        :empty -> false
        {:leaf, ^el} -> true
        {:leaf, _el} -> false
        {:inner, ^el, _l, _r} -> true
        {:inner, _el, l, r} -> l or r
      end
    end

    # count only the leafs
    def count_leafs(tree) do
      case tree do
        # empty nodes are not counted
        :empty -> 0
        {:leaf, _v} -> 1
        # for inner nodes be just sum the children results
        {:inner, _v, l, r} -> l + r
      end
    end

    # count all nodes except :empty
    def count_nodes(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, l, r} -> 1 + l + r
      end
    end

    # count only inner nodes
    def count_inner(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 0
        {:inner, l, r} -> 1 + l + r
      end
    end

    # count only empty nodes
    def count_empty(tree) do
      case tree do
        :empty -> 1
        {:leaf, _v} -> 0
        {:inner, l, r} -> l + r
      end
    end

    # calculate the max tree height
    def height(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, _v, l, r} -> 1 + max(l, r)
      end
    end

    # minimum height (shortest path from root to leaf)
    def min_height(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, _v, l, r} -> 1 + min(l, r)
      end
    end

    # check if the tree is balanced by calculating the largest
    # height difference betwen left and right children across the tree
    def skew_height(tree) do
      case tree do
        :empty ->
          {0, 0}

        {:leaf, _v} ->
          {0, 1}

        {:inner, _v, {skew_l, l}, {skew_r, r}} ->
          {
            max(abs(r - l), max(skew_l, skew_r)),
            1 + max(l, r)
          }
      end
    end

    defp maxi(:neginf, a), do: a
    defp maxi(a, :neginf), do: a
    defp maxi(a, b), do: Kernel.max(a, b)
  end
end

Kino.nothing()
```

