## Gaußian Sum and Faculty

Next lets compose some *Anamorphisms* with *Catamorphisms*.

Lets *first* generate a `List` and *then* reduce it down its `sum` or to its `product`.

```elixir
# multiply integers from 1 to 5
5 # <-- seed value
|> Anamorphism.ana(
  # build list of integers from 5 to 1
  &LinkedListStructure.recursion/2, # <-- structure to generate (List)
  &LinkedListStructure.CoAlgebras.countdown/1 # <-- generator
)
|> Catamorphism.cata(
  &LinkedListStructure.recursion/2,  # <-- structure to reduce (List as well)
  # reduce the list via multiplication
  &LinkedListStructure.Algebras.product/1 # <--- reduction to apply
)
|> IO.inspect(label: "5 Faculity")

# sum integers from 1 to 100
100 # <-- seed value
|> Anamorphism.ana(
  # build list of integers from 100 to 1
  &LinkedListStructure.recursion/2,  # <-- structure to generate (List)
  &LinkedListStructure.CoAlgebras.countdown/1  # <-- generator
)
|> Catamorphism.cata(
  &LinkedListStructure.recursion/2, # <-- structure to reduce (List as well)
  # reduce the list via summation
  &LinkedListStructure.Algebras.sum/1 # <--- reduction to apply
)
|> IO.inspect(label: "Sum of integers from 1 to 100")

Kino.nothing()
```

<!-- livebook:{"output":true} -->

```
5 Faculity: 120
Sum of integers from 1 to 100: 5050
```

Instead of first using ana and then cata, we can combine both calls into hylo.

```elixir
# multiply integers from 1 to 5
5  # <-- seed value
|> Hylomorphism.hylo(
  &LinkedListStructure.recursion/2, # <-- structure to generate AND reduce (List)
  # build list of integers from 5 to 1
  &LinkedListStructure.CoAlgebras.countdown/1, # <-- generator
  # reduce the list via multiplication
  &LinkedListStructure.Algebras.product/1 # <--- reducer
)
|> IO.inspect(label: "5 Faculity")

# sum integers from 1 to 100
100  # <-- seed value
|> Hylomorphism.hylo(
  &LinkedListStructure.recursion/2, # <-- structure to generate AND reduce (List)
  # build list of integers from 100 to 1 
  &LinkedListStructure.CoAlgebras.countdown/1, # <-- generator
  # reduce the list via summation
  &LinkedListStructure.Algebras.sum/1 # <--- reducer
)
|> IO.inspect(label: "Sum of integers from 1 to 100")

Kino.nothing()
```

<!-- livebook:{"output":true} -->

```
5 Faculity: 120
Sum of integers from 1 to 100: 5050
```

## LeafTreeStructure

Lets define another structure, this time with recursion structure, *Algebras* and *Coalgebras* all packaged into one module.

```elixir
defmodule LeafTreeStructure do
  # Our binary tree shall consist of either
  # - leafs that store values
  # - or inner nodes that have two children but NO own values
  def recursion(tree, fun) do
    case tree do
      {:leaf, value} ->
        {:leaf, value}

      {:inner, left, right} ->
        {
          :inner,
          # fun.() markes the recursive fields again
          fun.(left),
          # fun.() markes the recursive fields again
          fun.(right)
        }
    end
  end

  # reducing a tree into a single values
  defmodule Algebras do
    # minimum value of a tree
    def min(tree) do
      case tree do
        # the min of a leaf is its value
        {:leaf, v} -> v
        # the minimum of an inner node is  the min of the children
        {:inner, l, r} -> min(l, r)
      end
    end

    def max(tree) do
      case tree do
        {:leaf, v} -> v
        {:inner, l, r} -> max(l, r)
      end
    end

    def sum(tree) do
      case tree do
        {:leaf, v} -> v
        {:inner, l, r} -> l + r
      end
    end

    def product(tree) do
      case tree do
        {:leaf, v} -> v
        {:inner, l, r} -> l * r
      end
    end

    def count_leafs(tree) do
      case tree do
        {:leaf, _v} -> 1
        {:inner, l, r} -> l + r
      end
    end

    def count_inner(tree) do
      case tree do
        {:leaf, _v} -> 0
        {:inner, l, r} -> 1 + l + r
      end
    end

    def count_nodes(tree) do
      case tree do
        {:leaf, _v} -> 1
        {:inner, l, r} -> 1 + l + r
      end
    end

    # assume the tree contains lists as values,
    # we can reduce the tree into a single list by merging two children lists
    def merge(n) do
      case n do
        {:leaf, list} -> list
        {:inner, left, right} -> merge(left, right)
      end
    end

    defp merge([], right), do: right
    defp merge(left, []), do: left
    defp merge([l | ls], [r | rs]) when l <= r, do: [l | merge(ls, [r | rs])]
    defp merge([l | ls], [r | rs]), do: [r | merge([l | ls], rs)]
  end

  # co algebras can generate trees from a seed
  defmodule CoAlgebras do
    # generate a balanced tree of given height
    def grow_balanced(height) do
      case height do
        0 -> {:leaf, 0}
        1 -> {:leaf, 1}
        h -> {:inner, h - 1, h - 1}
      end
    end

    # generate a barely balanced tree
    # the height of two child tree differ by exactly one
    def grow_barely_balanced(num) do
      case num do
        # height 0 -> a single node
        0 -> {:leaf, 0}
        # height 1 -> a single node
        1 -> {:leaf, 1}
        # an barely balanced node
        n -> {:inner, n - 1, n - 2}
      end
    end

    # turns list into a tree by splitting in the middle
    def from_list(list) do
      case list do
        # empty list is put into a single leaf
        [] ->
          {:leaf, []}

        # singleton list is put into a single leaf
        [x] ->
          {:leaf, [x]}

        # longers lists are split in half and each half is turn into a tree
        l ->
          mid = div(length(l), 2)
          {left, right} = Enum.split(l, mid)
          {:inner, left, right}
      end
    end

    # generate a tree containing values from start to (leaf_count-1) in its leafs
    def from_size({start, leaf_count}) do
      case leaf_count do
        1 ->
          {:leaf, start}

        n ->
          left_size = div(n, 2)
          right_size = n - left_size
          {:inner, {start, left_size}, {start + left_size, right_size}}
      end
    end
  end
end

Kino.nothing()
```

## Fibonacci

We can use our `LeafTreeStructure` to calculate fibonacci numbers:

```elixir
8
|> Anamorphism.ana(
  # grow barely balanced tree of height 8 with
  # leafs that each contain a 1 as their value 
  &LeafTreeStructure.recursion/2,
  &LeafTreeStructure.CoAlgebras.grow_barely_balanced/1
)
|> Catamorphism.cata(
  # sum up all trees values
  &LeafTreeStructure.recursion/2,
  &LeafTreeStructure.Algebras.sum/1
)
|> IO.inspect(label: "Fibonacci of 8")

Kino.nothing()
```

<!-- livebook:{"output":true} -->

```
Fibonacci of 8: 21
```

Again we can combine ana and cata into hylo and instead of  `LeafTreeStructure` we can even use our `SparseTreeStructure` to calculate the same result, but this time via counting leafs instead of summing them.

```elixir
8
|> Hylomorphism.hylo(
  &LeafTreeStructure.recursion/2,
  # generate barely balacned tree of height 8 with leafs all having value 1
  &LeafTreeStructure.CoAlgebras.grow_barely_balanced/1,
  # sum up all values 
  &LeafTreeStructure.Algebras.sum/1
)
|> IO.inspect(label: "Fibonacci of 8")

Kino.nothing()

8
|> Hylomorphism.hylo(
  # generate barely balanced tree and count the leafs
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.CoAlgebras.grow_barely_balanced/1,
  &SparseTreeStructure.Algebras.count_leafs/1
)
|> IO.inspect(label: "Fibonacci of 8")

Kino.nothing()
```

<!-- livebook:{"output":true} -->

```
Fibonacci of 8: 21
Fibonacci of 8: 21
```

