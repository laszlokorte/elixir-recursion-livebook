Max Value: 108
Sum Value: 201
Product Value: 53415936
Height: 4
Min Height: 2
Balanced: {2, 4}
Contains 4: true
Contains 33: false
To String: "{{[23]:8:(X)}:4:{(X):16:{(X):42:[108]}}}"
