## Catamorphism

This recursion scheme is well known and is called *catamorphism*. *Cata* is greek for collapsing and what all our functions had in common is that they collapsed the given structure (list, tree, ...) into a single value. Yes, `Enum.reduce` is also a catamorphism but one that only works for `List` and `Stream`, not for `Tree`. In this sense our discovery is more general.

The fancy name for our `handleCases` callback function is "*Algebra*". It is called this way because it captures the rules for *turning a tree-like structure into a single value*, the same way that *algebra* in math is about manipulating symbolic expression trees and calculating their resulting value.

Lets acutally rename the `RecursiveReduction` module to `Catamorphism` and then look at some more examples of how concise some algorithms can be expressed now.

```elixir
# defmodule RecursiveReduction do
defmodule Catamorphism do
  # takes a data structure, and mapRecur callback for walking the structure
  # and and algebra callback for reducing a node into a single value
  def cata(data, mapRecur, algebra) do
    data
    |> mapRecur.(fn
      child -> cata(child, mapRecur, algebra)
    end)
    |> algebra.()
  end
end

Kino.nothing()
```

## SparseTreeStructure

Now we can express a recursive data structure as a combinations of mapping over its structure and so called algebras. Lets do this for sparse `Trees` again and package everything together into a module.

```elixir
defmodule SparseTreeStructure do
  # the structure of a tree with possibly empty nodes 
  def recursion(tree, fun) do
    case tree do
      :empty ->  # <- either empty
        :empty

      {:leaf, value} -> # <- or leaf
        {:leaf, value}

      {:inner, inner_value, left, right} -> # <- or an inner node with 
        {
          :inner,
          inner_value,
          fun.(left), # <--- fun.() two recursive children
          fun.(right) # <--- fun.() 
        }
    end
  end

  # all the reductions that we can apply to a SparseTreeStructure
  # the algebras are specific to the tree structure
  defmodule Algebras do
    def min(tree) do
      case tree do
        # The minimum of an empty tree is infinity
        :empty -> :infinity
        # The minimum of leaf is its values
        {:leaf, v} -> v
        # The minimum of an inner nodes is the minimum of both its children and its own balue
        {:inner, v, l, r} -> min(v, min(l, r))
      end
    end

    # calculate its max value
    def max(tree) do
      case tree do
        :empty -> :neginf
        {:leaf, v} -> v
        {:inner, v, l, r} -> maxi(v, maxi(l, r))
      end
    end

    # sum all values in both inner and leaf nodes
    def sum(tree) do
      case tree do
        :empty -> 0
        {:leaf, v} -> v
        {:inner, v, l, r} -> v + l + r
      end
    end

    # multiply all values
    def product(tree) do
      case tree do
        :empty -> 1
        {:leaf, v} -> v
        {:inner, v, l, r} -> v * l * r
      end
    end

    # turn the tree into a string of nested braces
    def to_string(tree) do
      case tree do
        :empty -> "(X)"
        {:leaf, v} -> "[#{v}]"
        {:inner, v, l, r} -> "{#{l}:#{v}:#{r}}"
      end
    end

    # check if the tree contains a value
    def contains(el) do
      fn
        :empty -> false
        {:leaf, ^el} -> true
        {:leaf, _el} -> false
        {:inner, ^el, _l, _r} -> true
        {:inner, _el, l, r} -> l or r
      end
    end

    # count only the leafs
    def count_leafs(tree) do
      case tree do
        # empty nodes are not counted
        :empty -> 0
        {:leaf, _v} -> 1
        # for inner nodes be just sum the children results
        {:inner, _v, l, r} -> l + r
      end
    end

    # count all nodes except :empty
    def count_nodes(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, l, r} -> 1 + l + r
      end
    end

    # count only inner nodes
    def count_inner(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 0
        {:inner, l, r} -> 1 + l + r
      end
    end

    # count only empty nodes
    def count_empty(tree) do
      case tree do
        :empty -> 1
        {:leaf, _v} -> 0
        {:inner, l, r} -> l + r
      end
    end

    # calculate the max tree height
    def height(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, _v, l, r} -> 1 + max(l, r)
      end
    end

    # minimum height (shortest path from root to leaf)
    def min_height(tree) do
      case tree do
        :empty -> 0
        {:leaf, _v} -> 1
        {:inner, _v, l, r} -> 1 + min(l, r)
      end
    end

    # check if the tree is balanced by calculating the largest
    # height difference betwen left and right children across the tree
    def skew_height(tree) do
      case tree do
        :empty ->
          {0, 0}

        {:leaf, _v} ->
          {0, 1}

        {:inner, _v, {skew_l, l}, {skew_r, r}} ->
          {
            max(abs(r - l), max(skew_l, skew_r)),
            1 + max(l, r)
          }
      end
    end

    defp maxi(:neginf, a), do: a
    defp maxi(a, :neginf), do: a
    defp maxi(a, b), do: Kernel.max(a, b)
  end
end

Kino.nothing()
```

Look how concisely we can define all these reductions!

## Reducing SparseTreeStructure

Now that we have defined the structure of our `simpleBinaryTreeWithEmptyNode` via `SparseTreeStructure` we can calculate all the various reductions.

```elixir
# calling `cata` with both the matching `recursion` function and the corresponding algebra:
simpleBinaryTreeWithEmptyNode # <- data
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2, # <- recursion 
  &SparseTreeStructure.Algebras.min/1 # <- algebra
)
|> IO.inspect(label: "Min Value")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.max/1
)
|> IO.inspect(label: "Max Value")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.sum/1
)
|> IO.inspect(label: "Sum Value")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.product/1
)
|> IO.inspect(label: "Product Value")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.height/1
)
|> IO.inspect(label: "Height")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.min_height/1
)
|> IO.inspect(label: "Min Height")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.skew_height/1
)
|> IO.inspect(label: "Balanced")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  SparseTreeStructure.Algebras.contains(4)
)
|> IO.inspect(label: "Contains 4")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  SparseTreeStructure.Algebras.contains(33)
)
|> IO.inspect(label: "Contains 33")

simpleBinaryTreeWithEmptyNode
|> Catamorphism.cata(
  &SparseTreeStructure.recursion/2,
  &SparseTreeStructure.Algebras.to_string/1
)
|> IO.inspect(label: "To String")

Kino.nothing()
```

<!-- livebook:{"output":true} -->

